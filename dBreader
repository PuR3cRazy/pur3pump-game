<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>How Loud?!</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: #0f0f0f;
    color: #f0f0f0;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    text-align: center;
  }
  h1 { font-size: 22px; font-weight: 500; margin-bottom: 4px; }
  .subtitle { font-size: 13px; color: #888; margin-bottom: 2rem; }

  .dial-wrap { position: relative; width: 260px; height: 260px; margin-bottom: 1.5rem; }
  svg { transform: rotate(-90deg); }
  .dial-bg { fill: none; stroke: #1a1a1a; stroke-width: 14; }
  .dial-fg { fill: none; stroke-width: 14; stroke-linecap: round; transition: stroke-dashoffset 0.15s ease, stroke 0.3s ease; }
  .dial-center {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
  }
  .db-value { font-size: 48px; font-weight: 600; line-height: 1; }
  .db-unit { font-size: 13px; color: #888; margin-top: 2px; }

  .label-card {
    background: #1a1a1a;
    border: 0.5px solid #2a2a2a;
    border-radius: 16px;
    padding: 1.2rem 1.5rem;
    margin-bottom: 1.5rem;
    min-width: 260px;
    max-width: 320px;
    transition: border-color 0.3s ease;
  }
  .label-name { font-size: 22px; font-weight: 600; margin-bottom: 6px; }
  .label-text { font-size: 16px; font-weight: 500; }

  .btn {
    padding: 12px 32px;
    border-radius: 10px;
    border: 0.5px solid #444;
    background: #1a1a1a;
    color: #f0f0f0;
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
  }
  .btn:hover { background: #222; }
  .btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .btn.listening { border-color: #D85A30; color: #D85A30; }

  .error-msg { font-size: 13px; color: #D85A30; margin-top: 1rem; max-width: 280px; }
  .peak-row { font-size: 12px; color: #555; margin-top: 1rem; }
  .footer-note { font-size: 11px; color: #333; margin-top: 2rem; max-width: 280px; }
</style>
</head>
<body>

<h1>How Loud?! 📢</h1>
<p class="subtitle">Real-time volume meter with commentary</p>

<div class="dial-wrap">
  <svg width="260" height="260" viewBox="0 0 260 260">
    <circle class="dial-bg" cx="130" cy="130" r="110" />
    <circle id="dial-fg" class="dial-fg" cx="130" cy="130" r="110"
      stroke-dasharray="691.15" stroke-dashoffset="691.15" stroke="#1D9E75" />
  </svg>
  <div class="dial-center">
    <div class="db-value" id="db-value">--</div>
    <div class="db-unit">dB (est.)</div>
  </div>
</div>

<div class="label-card" id="label-card">
  <div class="label-name" id="label-name">Ready?</div>
  <div class="label-text" id="label-text">Tap start and make some noise</div>
</div>

<button class="btn" id="toggle-btn" onclick="toggleListening()">Start Listening</button>
<div class="peak-row" id="peak-row"></div>
<div class="error-msg" id="error-msg"></div>

<div class="footer-note">
  Estimated reading based on phone mic input — not a calibrated dB SPL meter. Relative levels only, for fun!
</div>

<script>
// ─────────────────────────────────────────────
// THRESHOLD CONFIG — edit this array to create new
// seasonal/themed versions. Order matters: first
// matching range (by minDb) wins, sorted ascending.
// ─────────────────────────────────────────────
const THRESHOLDS = [
  { minDb: 0,  name: 'Whisper Wendy',        sub: 'Barely a peep',              color: '#1D9E75' },
  { minDb: 20, name: 'Casual Carl',          sub: 'Normal indoor voice',        color: '#1D9E75' },
  { minDb: 35, name: 'Excited Eddie',        sub: 'Getting into it now',        color: '#5DCAA5' },
  { minDb: 50, name: 'Baby-Waker Barb',      sub: "You've woken the baby",      color: '#BA7517' },
  { minDb: 65, name: 'Grandma-Alerter Gary', sub: 'Grandma heard that one',     color: '#EF9F27' },
  { minDb: 80, name: 'Neighborhood Nancy',   sub: 'The whole block knows now',  color: '#D85A30' },
  { minDb: 95, name: 'Cop-Calling Carl',     sub: "Someone's dialing 911",      color: '#FF3B3B' },
];
// Max dB used for the dial scale (visual only)
const DIAL_MAX_DB = 120;

// ─────────────────────────────────────────────
// APP STATE
// ─────────────────────────────────────────────
let audioCtx, analyser, micStream, rafId;
let listening = false;
let peakDb = 0;
let smoothedDb = 0;

const dbValueEl = document.getElementById('db-value');
const dialFgEl = document.getElementById('dial-fg');
const labelCardEl = document.getElementById('label-card');
const labelNameEl = document.getElementById('label-name');
const labelTextEl = document.getElementById('label-text');
const toggleBtnEl = document.getElementById('toggle-btn');
const errorMsgEl = document.getElementById('error-msg');
const peakRowEl = document.getElementById('peak-row');

const DIAL_CIRCUMFERENCE = 2 * Math.PI * 110; // ~691.15

function getThresholdFor(db) {
  let match = THRESHOLDS[0];
  for (const t of THRESHOLDS) {
    if (db >= t.minDb) match = t;
  }
  return match;
}

function updateUI(db) {
  const clamped = Math.max(0, Math.min(DIAL_MAX_DB, db));
  dbValueEl.textContent = Math.round(db);

  const pct = clamped / DIAL_MAX_DB;
  const offset = DIAL_CIRCUMFERENCE * (1 - pct);
  dialFgEl.style.strokeDashoffset = offset;

  const t = getThresholdFor(db);
  dialFgEl.style.stroke = t.color;
  labelNameEl.textContent = t.name;
  labelTextEl.textContent = t.sub;
  labelCardEl.style.borderColor = t.color;

  if (db > peakDb) peakDb = db;
  peakRowEl.textContent = `Peak this session: ${Math.round(peakDb)} dB`;
}

function analyze() {
  const bufferLength = analyser.fftSize;
  const dataArray = new Float32Array(bufferLength);
  analyser.getFloatTimeDomainData(dataArray);

  // Compute RMS (root mean square) of the waveform
  let sumSquares = 0;
  for (let i = 0; i < bufferLength; i++) {
    sumSquares += dataArray[i] * dataArray[i];
  }
  const rms = Math.sqrt(sumSquares / bufferLength);

  // Convert RMS to an approximate dB scale.
  // This is NOT calibrated SPL — it's a relative loudness estimate
  // mapped to a roughly intuitive 0-120 range for fun purposes.
  const minRms = 0.0001; // floor to avoid -Infinity
  const db = 20 * Math.log10(Math.max(rms, minRms) / minRms) * 0.6 + 20;

  // Smooth the reading so it doesn't jitter wildly
  smoothedDb = smoothedDb * 0.7 + db * 0.3;

  updateUI(smoothedDb);
  rafId = requestAnimationFrame(analyze);
}

async function startListening() {
  errorMsgEl.textContent = '';
  try {
    micStream = await navigator.mediaDevices.getUserMedia({ audio: true });
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    const source = audioCtx.createMediaStreamSource(micStream);
    analyser = audioCtx.createAnalyser();
    analyser.fftSize = 2048;
    source.connect(analyser);

    listening = true;
    peakDb = 0;
    toggleBtnEl.textContent = 'Stop Listening';
    toggleBtnEl.classList.add('listening');
    analyze();
  } catch (err) {
    console.error(err);
    errorMsgEl.textContent = 'Microphone access denied or unavailable. Please allow mic permission and try again.';
  }
}

function stopListening() {
  listening = false;
  if (rafId) cancelAnimationFrame(rafId);
  if (micStream) micStream.getTracks().forEach(track => track.stop());
  if (audioCtx) audioCtx.close();
  toggleBtnEl.textContent = 'Start Listening';
  toggleBtnEl.classList.remove('listening');
  dbValueEl.textContent = '--';
  dialFgEl.style.strokeDashoffset = DIAL_CIRCUMFERENCE;
  labelNameEl.textContent = 'Ready?';
  labelTextEl.textContent = 'Tap start and make some noise';
  labelCardEl.style.borderColor = '#2a2a2a';
}

function toggleListening() {
  if (listening) {
    stopListening();
  } else {
    startListening();
  }
}
</script>

</body>
</html>
