<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>How Loud?!</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
    background:#0f0f0f;
    color:#f0f0f0;
    min-height:100vh;
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    text-align:center;
    padding:24px;
}

h1{
    font-size:28px;
    margin-bottom:6px;
}

.subtitle{
    color:#888;
    margin-bottom:24px;
    font-size:14px;
}

.dial-wrap{
    position:relative;
    width:280px;
    height:280px;
    margin-bottom:16px;
}

svg{
    transform:rotate(-90deg);
}

.dial-bg{
    fill:none;
    stroke:#1a1a1a;
    stroke-width:14;
}

.dial-fg{
    fill:none;
    stroke-width:14;
    stroke-linecap:round;
    transition:.15s ease;
}

.dial-center{
    position:absolute;
    inset:0;
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
}

.character{
    font-size:72px;
    line-height:1;
    margin-bottom:8px;
    transition:.2s ease;
}

.db-value{
    font-size:46px;
    font-weight:700;
}

.db-unit{
    color:#888;
    font-size:12px;
}

.speech-bubble{
    background:#1a1a1a;
    border:1px solid #333;
    border-radius:16px;
    padding:12px 16px;
    margin-bottom:16px;
    max-width:320px;
    font-size:14px;
}

.label-card{
    background:#1a1a1a;
    border:1px solid #2a2a2a;
    border-radius:16px;
    padding:18px;
    width:320px;
    transition:.25s ease;
}

.label-name{
    font-size:22px;
    font-weight:700;
    margin-bottom:4px;
}

.label-text{
    color:#bbb;
}

.btn{
    margin-top:18px;
    padding:12px 32px;
    border:none;
    border-radius:10px;
    background:#222;
    color:white;
    cursor:pointer;
    font-size:15px;
}

.btn:hover{
    background:#2d2d2d;
}

.btn.listening{
    border:1px solid #ff7b4d;
    color:#ff7b4d;
}

#achievement{
    margin-top:16px;
    min-height:24px;
    color:gold;
    font-weight:700;
}

.peak-row{
    margin-top:12px;
    color:#666;
    font-size:12px;
}

.footer{
    margin-top:24px;
    color:#444;
    font-size:11px;
    max-width:320px;
}

.shake{
    animation:shake .15s infinite;
}

@keyframes shake{
    0%{transform:translateX(0);}
    25%{transform:translateX(-2px);}
    50%{transform:translateX(2px);}
    75%{transform:translateX(-2px);}
    100%{transform:translateX(0);}
}

</style>
</head>

<body>

<h1>How Loud?! 📢</h1>
<div class="subtitle">
Real-time volume meter with ridiculous commentary
</div>

<div class="dial-wrap" id="dial-wrap">

<svg width="280" height="280" viewBox="0 0 280 280">
    <circle
        class="dial-bg"
        cx="140"
        cy="140"
        r="115"/>

    <circle
        id="dial-fg"
        class="dial-fg"
        cx="140"
        cy="140"
        r="115"
        stroke="#1D9E75"
        stroke-dasharray="722"
        stroke-dashoffset="722"/>
</svg>

<div class="dial-center">

<div id="character" class="character">🤫</div>

<div id="db-value" class="db-value">--</div>
<div class="db-unit">dB (est.)</div>

</div>

</div>

<div id="speech-bubble" class="speech-bubble">
Tap Start and make some noise!
</div>

<div id="label-card" class="label-card">

<div id="label-name" class="label-name">
Ready?
</div>

<div id="label-text" class="label-text">
Waiting for microphone...
</div>

</div>

<button id="toggle-btn" class="btn">
Start Listening
</button>

<div id="achievement"></div>

<div id="peak-row" class="peak-row"></div>

<div class="footer">
Estimated reading based on microphone input.
For fun only, not a calibrated SPL meter.
</div>

<script>

const THRESHOLDS = [

{
minDb:0,
name:"Whisper Wendy",
sub:"Barely a peep",
quote:"Shhh... indoor voices.",
emoji:"🤫",
color:"#1D9E75"
},

{
minDb:20,
name:"Casual Carl",
sub:"Normal indoor voice",
quote:"Just chatting.",
emoji:"☕",
color:"#1D9E75"
},

{
minDb:35,
name:"Excited Eddie",
sub:"Getting into it now",
quote:"Now we're talking!",
emoji:"🎉",
color:"#5DCAA5"
},

{
minDb:50,
name:"Baby-Waker Barb",
sub:"You've woken the baby",
quote:"Great... now the baby is awake.",
emoji:"👶",
color:"#BA7517"
},

{
minDb:65,
name:"Grandma-Alerter Gary",
sub:"Grandma heard that one",
quote:"Grandma definitely heard that.",
emoji:"👵",
color:"#EF9F27"
},

{
minDb:80,
name:"Neighborhood Nancy",
sub:"The whole block knows now",
quote:"I already texted three neighbors.",
emoji:"🏠",
color:"#D85A30"
},

{
minDb:95,
name:"Cop-Calling Carl",
sub:"Someone's dialing 911",
quote:"Dispatch? Yes, it's happening again.",
emoji:"🚨",
color:"#FF3B3B"
},

{
minDb:110,
name:"Airhorn Andy",
sub:"WHY WOULD YOU DO THAT",
quote:"My ears just filed a complaint.",
emoji:"📯",
color:"#FF2222"
},

{
minDb:120,
name:"Apocalypse Alice",
sub:"Civilization has ended",
quote:"This is how it all ends.",
emoji:"☄️",
color:"#FF0000"
},

{
minDb:130,
name:"Nuclear Ned",
sub:"Physics has concerns",
quote:"Science says absolutely not.",
emoji:"☢️",
color:"#FFFFFF"
}

];

const ACHIEVEMENTS = [
{db:50,text:"🏆 Baby Destroyer"},
{db:80,text:"🏆 Neighborhood Menace"},
{db:95,text:"🏆 911 Speed Dial"},
{db:110,text:"🏆 Airhorn Champion"}
];

const circumference = 722;

let audioCtx;
let analyser;
let micStream;
let rafId;

let listening = false;
let peakDb = 0;
let smoothedDb = 0;

const unlocked = new Set();

const dbValueEl = document.getElementById("db-value");
const characterEl = document.getElementById("character");
const labelNameEl = document.getElementById("label-name");
const labelTextEl = document.getElementById("label-text");
const speechEl = document.getElementById("speech-bubble");
const dialFgEl = document.getElementById("dial-fg");
const labelCardEl = document.getElementById("label-card");
const peakRowEl = document.getElementById("peak-row");
const achievementEl = document.getElementById("achievement");
const buttonEl = document.getElementById("toggle-btn");
const dialWrapEl = document.getElementById("dial-wrap");

function getThreshold(db){

let current = THRESHOLDS[0];

for(const t of THRESHOLDS){
if(db >= t.minDb){
current = t;
}
}

return current;

}

function updateUI(db){

const threshold = getThreshold(db);

dbValueEl.textContent = Math.round(db);

characterEl.textContent = threshold.emoji;

labelNameEl.textContent = threshold.name;
labelTextEl.textContent = threshold.sub;
speechEl.textContent = threshold.quote;

labelCardEl.style.borderColor = threshold.color;
dialFgEl.style.stroke = threshold.color;

const pct = Math.min(db,130) / 130;

dialFgEl.style.strokeDashoffset =
circumference * (1 - pct);

if(db > peakDb){
peakDb = db;
}

peakRowEl.textContent =
"Peak this session: " +
Math.round(peakDb) +
" dB";

for(const achievement of ACHIEVEMENTS){

if(db >= achievement.db &&
!unlocked.has(achievement.db)){

unlocked.add(achievement.db);

achievementEl.textContent =
achievement.text;

}

}

if(db >= 95){
dialWrapEl.classList.add("shake");
}else{
dialWrapEl.classList.remove("shake");
}

}

function analyze(){

const bufferLength = analyser.fftSize;

const dataArray =
new Float32Array(bufferLength);

analyser.getFloatTimeDomainData(dataArray);

let sumSquares = 0;

for(let i=0;i<bufferLength;i++){
sumSquares += dataArray[i] * dataArray[i];
}

const rms =
Math.sqrt(sumSquares / bufferLength);

const db =
20 *
Math.log10(
Math.max(rms,0.0001) /
0.0001
) *
0.6 +
20;

smoothedDb =
smoothedDb * 0.7 +
db * 0.3;

updateUI(smoothedDb);

rafId =
requestAnimationFrame(analyze);

}

async function startListening(){

try{

micStream =
await navigator.mediaDevices.getUserMedia({
audio:true
});

audioCtx =
new (
window.AudioContext ||
window.webkitAudioContext
)();

const source =
audioCtx.createMediaStreamSource(
micStream
);

analyser =
audioCtx.createAnalyser();

analyser.fftSize = 2048;

source.connect(analyser);

listening = true;

peakDb = 0;

buttonEl.textContent =
"Stop Listening";

buttonEl.classList.add("listening");

analyze();

}catch(err){

alert(
"Microphone access denied or unavailable."
);

}

}

function stopListening(){

listening = false;

if(rafId){
cancelAnimationFrame(rafId);
}

if(micStream){
micStream
.getTracks()
.forEach(track => track.stop());
}

if(audioCtx){
audioCtx.close();
}

buttonEl.textContent =
"Start Listening";

buttonEl.classList.remove("listening");

dbValueEl.textContent = "--";

}

buttonEl.addEventListener("click",()=>{

if(listening){
stopListening();
}else{
startListening();
}

});

</script>

</body>
</html>
